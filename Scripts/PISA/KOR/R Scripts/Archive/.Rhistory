)
}
}
print("\nAll requested metrics have been computed and exported.")
# --- Define a special measurement model only for CB-SEM (lavaan naming constraints) ---
mm_cbsem <- constructs(
composite("SMP_lat", c(
"PV1MATH","PV2MATH","PV3MATH","PV4MATH","PV5MATH",
"PV6MATH","PV7MATH","PV8MATH","PV9MATH","PV10MATH"
)),
composite("SMS_lat", c(
"ST268Q01JA","ST268Q04JA","ST268Q07JA"
)),
composite("SPI_lat", c(
"SC064Q01TA","SC064Q02TA","SC064Q03TA",
"SC064Q04NA","SC064Q05WA","SC064Q06WA","SC064Q07WA"
)),
composite("gender_lat", "ST004D01T"),
composite("grade_lat", "ST001D01T"),
composite("motherEdu_lat", "MISCED"),
composite("ESCS_lat", "ESCS"),   # renamed to avoid collision
composite("age_lat", "AGE"),
composite("immig_lat", "IMMIG"),
composite("classSize_lat", "MCLSIZE"),
composite("schoolSize_lat", "SCHSIZE")
)
# --- Define structural model for CB-SEM (renamed latent variables) ---
sm_cbsem <- relationships(
paths(
from = c("SPI_lat", "gender_lat", "grade_lat", "motherEdu_lat",
"ESCS_lat", "age_lat", "immig_lat",
"classSize_lat", "schoolSize_lat"),
to = "SMS_lat"
),
paths(
from = c("SPI_lat", "SMS_lat", "gender_lat", "grade_lat",
"motherEdu_lat","ESCS_lat","age_lat","immig_lat",
"classSize_lat","schoolSize_lat"),
to = "SMP_lat"
)
)
# ------------------------------------------------
# Standardize observed variables for CB-SEM (lavaan requires comparable scales)
# ------------------------------------------------
df_cbsem <- df_clean %>%
mutate(across(everything(), scale)) %>%
as.data.frame()
# ------------------------------------------------
# Standardize observed variables for CB-SEM
# (lavaan requires comparable variances)
# ------------------------------------------------
# Identify numeric columns only
numeric_vars <- sapply(df_clean, is.numeric)
df_cbsem <- df_clean
# Scale ONLY numeric columns
df_cbsem[, numeric_vars] <- scale(df_clean[, numeric_vars])
# Convert all columns to numeric explicitly (lavaan requirement)
df_cbsem <- data.frame(lapply(df_cbsem, function(x) as.numeric(as.character(x))))
# --- Fit CB-SEM ---
cbsem_model <- tryCatch({
estimate_cbsem(
data = df_cbsem,
measurement_model = as.reflective(mm_cbsem),
structural_model  = sm_cbsem
)
}, error = function(e) {
print(paste("CB-SEM estimation failed:", e$message))
NULL
})
# ------------------------------------------------
# CB-SEM FIT MEASURES (CFI, TLI, RMSEA, SRMR, χ², df)
# ------------------------------------------------
if (!is.null(cbsem_model)) {
# extract underlying lavaan object
lavaan_mod <- cbsem_model$lavaan_model
# global fit indices (same as those expected in SEM papers)
fit_indices <- fitMeasures(
lavaan_mod,
c("cfi", "tli", "rmsea", "srmr", "chisq", "df")
)
fit_df <- data.frame(
Metric = names(fit_indices),
Value  = as.numeric(fit_indices)
)
print("\nCB-SEM global fit indices (lavaan):")
print(fit_df)
# save to CSV
write_csv(
fit_df,
file.path(DATA_DIR, glue("sem_full_cbsem_fit_{CNT}.csv"))
)
# ------------------------------------------------
# PARAMETER ESTIMATES (UNSTD, STD.ALL, SE, P)
# ------------------------------------------------
param_tbl <- parameterEstimates(
lavaan_mod,
standardized = TRUE
)
print("\nCB-SEM parameter estimates (lavaan):")
print(head(param_tbl))
write_csv(
param_tbl,
file.path(DATA_DIR, glue("sem_full_cbsem_parameters_{CNT}.csv"))
)
}
cbsem_model
attr(cbsem_model, "error")
# ------------------------------------------------
# 10. COMPREHENSIVE STRUCTURAL COHERENCE METRICS
# ------------------------------------------------
print("\nComputing comprehensive structural coherence metrics...")
# 10.1 Global PLS-SEM fit: SRMR (variance-based fit index)
srmr_vals <- tryCatch({
SRMR(pls_model)
}, error = function(e) {
print(paste("SRMR computation failed:", e$message))
NULL
})
if (!is.null(srmr_vals)) {
srmr_df <- data.frame(
Metric = names(srmr_vals),
Value  = as.numeric(srmr_vals)
)
print("PLS-SEM SRMR (saturated / estimated):")
